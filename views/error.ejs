<%- layout('layout.ejs') %>

<%- include('partials/success-flash.ejs', { success }) %>
<%- include('partials/error-flash.ejs', { error }) %>

<div class="alert alert-danger mt-5 shadow-sm" role="alert">
    <h4 class="alert-heading">
        <%= err.status %> - <%= err.message %>
    </h4>
    <hr>
    <p class="mb-0 text-muted" style="white-space: pre-wrap;"><%= err.stack %></p>
</div>