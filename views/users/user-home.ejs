<%- layout('layout.ejs') %>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>All Users</h1>
        <a href="/users/signup" class="btn btn-success">Join</a>
    </div>

    <div class="row">
        <% for (const user of userData) { %>
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title"><%= user.username %></h5>
                        <h6 class="card-subtitle mb-2 text-muted small">ID: <%= user._id %></h6>
                        <p class="card-text text-truncate"><%= user.bio || 'No bio provided.' %></p>
                        <p class="card-text small text-muted"><%= user.email %></p>
                        <a href="/users/<%= user._id %>" class="btn btn-sm btn-outline-primary">View Profile</a>
                    </div>
                </div>
            </div>
        <% } %>
    </div>
</div>