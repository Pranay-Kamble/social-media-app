<%- layout('layout.ejs') %>

<div class="mb-3">
    <a href="/users" class="btn btn-sm btn-secondary">&larr; Back to Users</a>
</div>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6 bg-white p-4 border rounded shadow-sm">
        <h2 class="border-bottom pb-2 mb-4">User Profile</h2>
        
        <%- include('../partials/success-flash.ejs', { success }) %>
        <%- include('../partials/error-flash.ejs', { error }) %>

        <div class="mb-4">
            <p><strong>Display Name:</strong> <%= userData.display_name %></p>
            <p><strong>Username:</strong> <%= userData.username %></p>
            <p><strong>Email:</strong> <%= userData.email %></p>
            <p><strong>Bio:</strong> <%= userData.bio || 'None' %></p>
            <p class="text-muted small"><strong>Registered On:</strong> <%= userData.registeredOn %></p>
        </div>

        <% if (currentUser && currentUser._id.equals(userData._id)) { %>
            <hr>
            <div class="d-flex gap-2 mt-4">
                <a href="/users/<%= userData._id %>/edit" class="btn btn-info text-white">Edit Details</a>
                <form action="/users/<%= userData._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Are you sure you want to delete your account?')">
                    <button type="submit" class="btn btn-danger">Delete Account</button>
                </form>
            </div>
        <% } %>
    </div>
</div>