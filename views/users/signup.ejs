<%- layout('layout.ejs') %>
<% const fieldErrors = typeof errors !== 'undefined' ? errors : {}; %>

<div class="row justify-content-center mt-4">
    <div class="col-md-8 col-lg-5 bg-white p-4 border rounded shadow-sm">
        <h3 class="text-center mb-4">Sign Up</h3>

        <%- include('../partials/success-flash.ejs', { success }) %>
        <%- include('../partials/error-flash.ejs', { error }) %>

        <form action="/users/signup" method="POST" novalidate>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label for="username" class="form-label">Username:</label>
                    <input class="form-control <%= fieldErrors.username ? 'is-invalid' : (user && user.username ? 'is-valid' : '') %>" 
                           type="text" id="username" name="username" value="<%= (user && user.username) || '' %>" required>
                    <div class="invalid-feedback"><%= fieldErrors.username %></div>
                </div>
                
                <div class="col-md-6 mb-3">
                    <label for="display_name" class="form-label">Display Name:</label>
                    <input class="form-control <%= fieldErrors.display_name ? 'is-invalid' : (user && user.display_name ? 'is-valid' : '') %>" 
                           type="text" id="display_name" name="display_name" value="<%= (user && user.display_name) || '' %>" required>
                    <div class="invalid-feedback"><%= fieldErrors.display_name %></div>
                </div>
            </div>

            <div class="mb-3">
                <label for="email" class="form-label">Email:</label>
                <input class="form-control <%= fieldErrors.email ? 'is-invalid' : (user && user.email ? 'is-valid' : '') %>" 
                       type="email" id="email" name="email" value="<%= (user && user.email) || '' %>" required>
                <div class="invalid-feedback"><%= fieldErrors.email %></div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label for="password" class="form-label">Password:</label>
                    <input class="form-control <%= fieldErrors.password ? 'is-invalid' : '' %>" 
                           type="password" id="password" name="password" required>
                    <div class="invalid-feedback"><%= fieldErrors.password %></div>
                </div>
                
                <div class="col-md-6 mb-3">
                    <label for="confirmpassword" class="form-label">Confirm Password:</label>
                    <input class="form-control <%= fieldErrors.confirmpassword ? 'is-invalid' : '' %>" 
                           type="password" id="confirmpassword" name="confirmpassword" required>
                    <div class="invalid-feedback"><%= fieldErrors.confirmpassword %></div>
                </div>
            </div>

            <div class="mb-4">
                <label for="bio" class="form-label">Bio (Optional):</label>
                <textarea class="form-control <%= fieldErrors.bio ? 'is-invalid' : (user && user.bio ? 'is-valid' : '') %>" 
                          id="bio" name="bio" rows="2"><%= (user && user.bio) || '' %></textarea>
                <div class="invalid-feedback"><%= fieldErrors.bio %></div>
            </div>

            <button class="btn btn-primary w-100" type="submit">Create Account</button>
        </form>
        
        <div class="text-center mt-3">
            <p class="small">Already have an account? <a href="/users/login" class="text-decoration-none">Log In</a></p>
        </div>
    </div>
</div>